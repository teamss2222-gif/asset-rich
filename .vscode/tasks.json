{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Deploy to Vercel (commit & push)",
      "type": "shell",
      "command": "git add -A && git diff --cached --quiet && echo '변경사항 없음' || (git commit -m \"deploy: $(Get-Date -Format 'yyyy-MM-dd HH:mm')\" && git push origin main && echo '✅ Vercel 배포 트리거 완료')",
      "options": {
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-Command"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔧 Dev server (npm run dev)",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
